DATABASE_URL=postgresql://nurix:nurix@postgres:5432/nurix
APP_PORT=8000

MAX_CONCURRENT_DEFAULT=5
MAX_CALL_DURATION_SECONDS=600
STUCK_RECLAIM_GET_STATUS_TIMEOUT_SECONDS=5
MAX_RETRIES_DEFAULT=3
RETRY_BACKOFF_BASE_SECONDS=30

SCHEDULER_SAFETY_NET_SECONDS=1
RECLAIM_SWEEP_INTERVAL_SECONDS=30

WEBHOOK_PROCESSOR_BATCH_MAX=50
WEBHOOK_INBOX_RETENTION_DAYS=7

MOCK_CALL_DURATION_SECONDS=3
MOCK_FAILURE_RATE=0.1
MOCK_NO_ANSWER_RATE=0.1

# DEMO_MODE=true bumps mock call duration to 15s, failure rate to 35%, and
# reclaim sweep interval to 5s — tuned for a reviewer to watch every rubric
# scenario unfold inside a 10-minute demo window.
DEMO_MODE=true
# DEBUG_ENDPOINTS_ENABLED=true mounts /debug/age-dialing. Required for the
# reclaim demo script; leave off in production environments.
DEBUG_ENDPOINTS_ENABLED=true

API_POOL_MIN=2
API_POOL_MAX=10
SCHEDULER_POOL_MIN=2
SCHEDULER_POOL_MAX=10
WEBHOOK_POOL_MIN=1
WEBHOOK_POOL_MAX=3

WEBHOOK_SIGNING_SECRET=
