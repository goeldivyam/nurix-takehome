APP_PORT=8000

MAX_CONCURRENT_DEFAULT=5
MAX_CALL_DURATION_SECONDS=600
STUCK_RECLAIM_GET_STATUS_TIMEOUT_SECONDS=5
MAX_RETRIES_DEFAULT=3
RETRY_BACKOFF_BASE_SECONDS=30

SCHEDULER_SAFETY_NET_SECONDS=1
RECLAIM_SWEEP_INTERVAL_SECONDS=30

WEBHOOK_PROCESSOR_BATCH_MAX=50
WEBHOOK_INBOX_RETENTION_DAYS=7

MOCK_CALL_DURATION_SECONDS=3
MOCK_FAILURE_RATE=0.1
MOCK_NO_ANSWER_RATE=0.1

DEMO_MODE=false
DEBUG_ENDPOINTS_ENABLED=false

API_POOL_MIN=2
API_POOL_MAX=10
